@page "/mes"
@using System.Globalization
@using GastosApp.Client.Models
@using GastosApp.Client.Services
@inject AuthService Auth
@inject AccountService Accounts
@inject CategoryService CategorySvc
@inject ExpenseService Expenses
@inject BudgetService Budgets
@inject NavigationManager Nav

<PageTitle>Vista del mes</PageTitle>

@if (isLoading)
{
    <p>Cargando...</p>
}
else if (accounts.Count == 0)
{
    <p>No tienes cuentas. <a href="setup">Configura tus cuentas</a>.</p>
}
else
{
    <div class="container-narrow stagger">

        @* Selector de mes *@
        <div class="d-flex justify-content-between align-items-center mb-3">
            <button class="btn btn-outline-secondary" @onclick="PreviousMonth">◀</button>
            <h4 class="m-0 text-capitalize">@MonthLabel</h4>
            <button class="btn btn-outline-secondary" @onclick="NextMonth">▶</button>
        </div>

        @* Botón añadir gasto rápido (preselecciona la cuenta activa) *@
        <a class="btn btn-primary w-100 mb-3"
           href="@($"nuevo-gasto?accountId={selectedAccountId}")">
            + Añadir gasto
        </a>

        @* Pestañas de cuenta *@
        <ul class="nav nav-tabs mb-3">
            @foreach (var acc in accounts)
            {
                <li class="nav-item">
                    <button class="nav-link @(selectedAccountId == acc.Id ? "active" : "")"
                            @onclick="() => SelectAccount(acc.Id)">
                        @acc.Name
                    </button>
                </li>
            }
        </ul>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        @* Bloque de saldos: una variante por tipo de cuenta *@
        <div class="balance-card mb-3">
            @if (IsCurrentAccountShared)
            {
                @* === COMPARTIDA: saldo inicial + aporte conjunto - gastos = saldo final === *@
                <div class="balance-row">
                    <span class="balance-label">Saldo inicial</span>
                    <span class="balance-value">
                        @(currentBudget?.OpeningBalance is decimal ob1
                            ? FormatMoney(ob1)
                            : SinDefinir())
                    </span>
                    <button class="btn btn-sm btn-outline-secondary"
                            @onclick="OpenOpeningBalanceModal">
                        @(currentBudget?.OpeningBalance is null ? "Establecer" : "Editar")
                    </button>
                </div>

                <div class="balance-row">
                    <span class="balance-label">Aporte conjunto</span>
                    <span class="balance-value">
                        @(currentBudget is null
                            ? SinDefinir()
                            : FormatMoney(currentBudget.Amount))
                    </span>
                    <button class="btn btn-sm btn-outline-secondary"
                            @onclick="OpenAmountModal">
                        @(currentBudget is null ? "Establecer" : "Editar")
                    </button>
                </div>

                <div class="balance-row">
                    <span class="balance-label">Gastos del mes</span>
                    <span class="balance-value text-danger">−@FormatMoney(currentTotal)</span>
                </div>

                <hr class="my-2"/>

                <div class="balance-row">
                    <span class="balance-label fw-bold">Saldo final</span>
                    <span class="balance-value fw-bold @(SaldoFinal() < 0 ? "text-danger" : "text-success")">
                        @(SaldoFinal() is decimal sf1 ? FormatMoney(sf1) : "—")
                    </span>
                </div>
            }
            else
            {
                @* === PERSONAL: saldo inicial + nómina - aporte_compartida - gastos = saldo final === *@
                <div class="balance-row">
                    <span class="balance-label">Saldo inicial</span>
                    <span class="balance-value">
                        @(currentBudget?.OpeningBalance is decimal ob2
                            ? FormatMoney(ob2)
                            : SinDefinir())
                    </span>
                    <button class="btn btn-sm btn-outline-secondary"
                            @onclick="OpenOpeningBalanceModal">
                        @(currentBudget?.OpeningBalance is null ? "Establecer" : "Editar")
                    </button>
                </div>

                <div class="balance-row">
                    <span class="balance-label">Nómina</span>
                    <span class="balance-value">
                        @(currentBudget?.Income is decimal inc
                            ? FormatMoney(inc)
                            : SinDefinir())
                    </span>
                    <button class="btn btn-sm btn-outline-secondary"
                            @onclick="OpenIncomeModal">
                        @(currentBudget?.Income is null ? "Establecer" : "Editar")
                    </button>
                </div>

                <div class="balance-row">
                    <span class="balance-label">
                        Aporte a compartida
                        <small class="text-muted">(50% de @FormatMoney(sharedAmount))</small>
                    </span>
                    <span class="balance-value text-danger">−@FormatMoney(AporteACompartida())</span>
                </div>

                <div class="balance-row">
                    <span class="balance-label">Gastos personales</span>
                    <span class="balance-value text-danger">−@FormatMoney(currentTotal)</span>
                </div>

                <hr class="my-2"/>

                <div class="balance-row">
                    <span class="balance-label fw-bold">Saldo final</span>
                    <span class="balance-value fw-bold @(SaldoFinal() < 0 ? "text-danger" : "text-success")">
                        @(SaldoFinal() is decimal sf2 ? FormatMoney(sf2) : "—")
                    </span>
                </div>
            }
        </div>

        @* Bloques de categorías agrupados *@
        @if (currentExpenses.Count == 0)
        {
            <p class="text-muted text-center my-4">No hay gastos en esta cuenta este mes.</p>
        }
        else
        {
            @foreach (var blockKey in BlocksForSelectedAccount())
            {
                var blockExpenses = currentExpenses
                    .Where(e => CategoryOf(e.CategoryId)?.Block == blockKey)
                    .ToList();

                var blockTotal = blockExpenses.Sum(e => e.Amount);
                var isExpanded = expandedBlocks.Contains(blockKey);

                <div class="block-card mb-2">
                    <button class="block-header" @onclick="() => ToggleBlock(blockKey)">
                        <span class="block-arrow @(isExpanded ? "expanded" : "")">▸</span>
                        <span class="block-name">@BlockLabel(blockKey)</span>
                        <span class="block-count text-muted">@blockExpenses.Count</span>
                        <span class="block-total">@FormatMoney(blockTotal)</span>
                    </button>

                    @* Wrapper siempre presente. La animación va por CSS:
                       grid-template-rows 0fr → 1fr cuando .expanded *@
                    <div class="block-content-wrap @(isExpanded ? "expanded" : "")">
                        <div class="block-content">
                            @if (blockExpenses.Count == 0)
                            {
                                <div class="block-empty text-muted small">Sin gastos en este bloque.</div>
                            }
                            else
                            {
                                <ul class="list-unstyled mb-0">
                                    @foreach (var exp in blockExpenses.OrderByDescending(e => e.ExpenseDate))
                                    {
                                        <li class="expense-row">
                                            <div class="expense-main">
                                                <div class="expense-title">
                                                    @(string.IsNullOrWhiteSpace(exp.Description)
                                                        ? CategoryOf(exp.CategoryId)?.Name ?? "(sin categoría)"
                                                        : exp.Description)
                                                </div>
                                                <div class="expense-meta text-muted small">
                                                    @exp.ExpenseDate.ToString("dd MMM", new CultureInfo("es-ES"))
                                                    · @(CategoryOf(exp.CategoryId)?.Name ?? "—")
                                                </div>
                                            </div>
                                            <div class="expense-amount">@FormatMoney(exp.Amount)</div>
                                            <div class="expense-actions">
                                                <a class="btn btn-sm btn-outline-secondary"
                                                   href="@($"nuevo-gasto?id={exp.Id}")">
                                                    Editar
                                                </a>
                                                <button class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => HandleDelete(exp)">
                                                    Borrar
                                                </button>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
}

@* Modal de borrado de gasto *@
<ConfirmModal @ref="confirmModal"
              Title="Borrar gasto"
              Message="Esta acción no se puede deshacer."
              ConfirmText="Borrar"
              ConfirmClass="btn-danger" />

@* Modal genérico para editar un campo numérico (saldo / nómina / aporte) *@
@if (numberModalVisible)
{
    <div class="modal-backdrop-custom" @onclick="CloseNumberModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <h5 class="mb-2">@numberModalTitle</h5>
            @if (!string.IsNullOrEmpty(numberModalHint))
            {
                <p class="text-muted small mb-3">@numberModalHint</p>
            }

            <div class="input-group input-group-lg mb-3">
                <input type="number"
                       inputmode="decimal"
                       step="0.01"
                       class="form-control"
                       placeholder="0,00"
                       @bind="numberInput"
                       @bind:event="oninput" />
                <span class="input-group-text">€</span>
            </div>

            @if (!string.IsNullOrEmpty(numberModalError))
            {
                <div class="alert alert-danger small">@numberModalError</div>
            }

            <div class="d-flex gap-2 justify-content-end">
                <button class="btn btn-outline-secondary"
                        @onclick="CloseNumberModal"
                        disabled="@isSavingNumber">
                    Cancelar
                </button>
                <button class="btn btn-primary"
                        @onclick="SaveNumberModal"
                        disabled="@(isSavingNumber || numberInput is null)">
                    @(isSavingNumber ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

<style>
    .container-narrow {
        max-width: 600px;
        margin: 0 auto;
        padding: 16px;
    }

    .balance-card {
        background: white;
        border: 1px solid #dee2e6;
        border-radius: 12px;
        padding: 16px 18px;
    }

    .balance-row {
        display: grid;
        grid-template-columns: 1fr auto auto;
        gap: 12px;
        align-items: center;
        padding: 4px 0;
    }

    .balance-label { color: #6c757d; }
    .balance-value { font-weight: 500; text-align: right; }

    .block-card {
        border: 1px solid #dee2e6;
        border-radius: 8px;
        overflow: hidden;
        background: white;
    }

    .block-header {
        width: 100%;
        display: grid;
        grid-template-columns: 24px 1fr auto auto;
        gap: 8px;
        align-items: center;
        padding: 12px 14px;
        background: #f8f9fa;
        border: none;
        text-align: left;
        cursor: pointer;
    }

    .block-header:hover { background: #e9ecef; }

    .block-arrow {
        color: #6c757d;
        font-size: 0.9rem;
        transition: transform 0.2s ease-out;
        display: inline-block;
    }
    .block-arrow.expanded { transform: rotate(90deg); }

    /* Truco moderno para animar height: auto.
       grid-template-rows interpola entre 0fr y 1fr → el hijo se "extiende"
       suavemente desde alto 0 hasta su alto natural. min-height: 0 en el
       hijo es necesario para que el grid pueda comprimirlo a 0. */
    .block-content-wrap {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.25s ease-out;
    }
    .block-content-wrap.expanded {
        grid-template-rows: 1fr;
    }
    .block-content {
        overflow: hidden;
        min-height: 0;
    }
    .block-name  { font-weight: 600; }
    .block-count {
        background: #dee2e6;
        border-radius: 10px;
        padding: 2px 8px;
        font-size: 0.8rem;
    }
    .block-total { font-weight: 600; }

    .block-empty { padding: 10px 14px; }

    .expense-row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 8px;
        padding: 10px 14px;
        border-top: 1px solid #f0f0f0;
        align-items: center;
    }

    .expense-main { min-width: 0; }
    .expense-title {
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .expense-meta { font-size: 0.8rem; }
    .expense-amount { font-weight: 600; }

    .expense-actions {
        grid-column: 1 / -1;
        display: flex;
        gap: 6px;
        margin-top: 4px;
    }

    /* Modal (mismo look que ConfirmModal) */
    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1050;
        padding: 16px;
        animation: fade-in-up 0.18s ease-out both;
    }

    .modal-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        max-width: 400px;
        width: 100%;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        animation: pop-in 0.22s ease-out both;
    }
</style>

@code {
    private bool isLoading = true;
    private string errorMessage = "";

    private List<Account> accounts = new();
    private Dictionary<Guid, Category> categoryMap = new();
    private List<Expense> currentExpenses = new();
    private MonthlyBudget? currentBudget;

    // Previsión de la cuenta compartida en el mes actual.
    // La necesitamos para calcular el aporte cuando la pestaña activa es personal.
    private MonthlyBudget? sharedBudgetThisMonth;

    private Guid selectedAccountId;
    private int currentYear;
    private int currentMonth;

    private HashSet<string> expandedBlocks = new();

    private ConfirmModal? confirmModal;

    // === Modal genérico de número ===
    private bool numberModalVisible = false;
    private bool isSavingNumber = false;
    private decimal? numberInput;
    private string numberModalTitle = "";
    private string numberModalHint = "";
    private string numberModalError = "";
    private Func<decimal, Task>? numberModalOnSave;

    // TODO: cuando entre Marta y queramos soportar share_percent dinámico,
    // leerlo de account_members del usuario en la cuenta compartida.
    // Por ahora siempre 50%.
    private const decimal MyShareInShared = 0.5m;

    private static readonly string[] SharedBlocks = { "fijo", "comida", "variable", "minicompra" };
    private static readonly string[] PersonalBlocks = { "individual" };

    private string MonthLabel
    {
        get
        {
            var date = new DateTime(currentYear, currentMonth, 1);
            return date.ToString("MMMM yyyy", new CultureInfo("es-ES"));
        }
    }

    private decimal currentTotal => currentExpenses.Sum(e => e.Amount);

    private Account? CurrentAccount =>
        accounts.FirstOrDefault(a => a.Id == selectedAccountId);

    private bool IsCurrentAccountShared => CurrentAccount?.IsShared == true;

    private Account? SharedAccount => accounts.FirstOrDefault(a => a.IsShared);

    private decimal sharedAmount => sharedBudgetThisMonth?.Amount ?? 0m;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("login");
            return;
        }

        var today = DateTime.Today;
        currentYear = today.Year;
        currentMonth = today.Month;

        accounts = (await Accounts.GetMyAccountsAsync())
            .OrderBy(a => a.IsShared)
            .ToList();

        if (accounts.Count == 0)
        {
            isLoading = false;
            return;
        }

        selectedAccountId = accounts.First().Id;

        await LoadAllCategories();
        await LoadMonthData();

        isLoading = false;
    }

    private async Task LoadAllCategories()
    {
        categoryMap.Clear();
        foreach (var acc in accounts)
        {
            var cats = await CategorySvc.GetByAccountAsync(acc.Id);
            foreach (var c in cats)
                categoryMap[c.Id] = c;
        }
    }

    private async Task LoadMonthData()
    {
        await LoadExpenses();
        await LoadBudgets();
    }

    private async Task LoadExpenses()
    {
        try
        {
            errorMessage = "";
            var all = await Expenses.GetByMonthAsync(currentYear, currentMonth);
            currentExpenses = all
                .Where(e => e.AccountId == selectedAccountId)
                .ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar gastos: {ex.Message}";
            currentExpenses = new();
        }
    }

    private async Task LoadBudgets()
    {
        try
        {
            currentBudget = await Budgets.GetForMonthAsync(selectedAccountId, currentYear, currentMonth);

            // Si la cuenta activa es personal, también cargamos la previsión de
            // la compartida para calcular el aporte. Si la activa ya es la
            // compartida, ese mismo budget también nos vale.
            if (IsCurrentAccountShared)
            {
                sharedBudgetThisMonth = currentBudget;
            }
            else if (SharedAccount is not null)
            {
                sharedBudgetThisMonth = await Budgets.GetForMonthAsync(
                    SharedAccount.Id, currentYear, currentMonth);
            }
            else
            {
                sharedBudgetThisMonth = null;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar previsión: {ex.Message}";
            currentBudget = null;
            sharedBudgetThisMonth = null;
        }
    }

    private async Task SelectAccount(Guid accountId)
    {
        selectedAccountId = accountId;
        expandedBlocks.Clear();
        await LoadMonthData();
    }

    private async Task PreviousMonth()
    {
        var date = new DateTime(currentYear, currentMonth, 1).AddMonths(-1);
        currentYear = date.Year;
        currentMonth = date.Month;
        expandedBlocks.Clear();
        await LoadMonthData();
    }

    private async Task NextMonth()
    {
        var date = new DateTime(currentYear, currentMonth, 1).AddMonths(1);
        currentYear = date.Year;
        currentMonth = date.Month;
        expandedBlocks.Clear();
        await LoadMonthData();
    }

    private void ToggleBlock(string blockKey)
    {
        if (!expandedBlocks.Add(blockKey))
            expandedBlocks.Remove(blockKey);
    }

    private Category? CategoryOf(Guid categoryId) =>
        categoryMap.TryGetValue(categoryId, out var c) ? c : null;

    private string[] BlocksForSelectedAccount() =>
        IsCurrentAccountShared ? SharedBlocks : PersonalBlocks;

    private async Task HandleDelete(Expense exp)
    {
        if (confirmModal is null) return;

        var confirmed = await confirmModal.ShowAsync();
        if (!confirmed) return;

        try
        {
            await Expenses.DeleteAsync(exp.Id);
            await LoadExpenses();
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudo borrar el gasto: {ex.Message}";
        }
    }

    // ===== Cálculos derivados =====

    private decimal AporteACompartida()
    {
        if (IsCurrentAccountShared) return 0m;
        return sharedAmount * MyShareInShared;
    }

    /// <summary>
    /// Saldo final del mes para la cuenta activa.
    /// Devuelve null si falta opening_balance (no se puede calcular).
    /// </summary>
    private decimal? SaldoFinal()
    {
        if (currentBudget?.OpeningBalance is not decimal opening) return null;

        if (IsCurrentAccountShared)
        {
            // Compartida: saldo_inicial + aporte_conjunto − gastos
            var entradas = currentBudget?.Amount ?? 0m;
            return opening + entradas - currentTotal;
        }
        else
        {
            // Personal: saldo_inicial + nómina − aporte_a_compartida − gastos
            var nomina = currentBudget?.Income ?? 0m;
            return opening + nomina - AporteACompartida() - currentTotal;
        }
    }

    // ===== Modales =====

    private async Task OpenOpeningBalanceModal()
    {
        numberModalTitle = "Saldo inicial del mes";
        numberModalError = "";
        numberModalOnSave = async (value) =>
        {
            currentBudget = await Budgets.SetOpeningBalanceAsync(
                selectedAccountId, currentYear, currentMonth, value);
            if (IsCurrentAccountShared) sharedBudgetThisMonth = currentBudget;
        };

        if (currentBudget?.OpeningBalance is decimal existing)
        {
            // Ya tenemos saldo definido: precargamos el actual para editar.
            numberInput = existing;
            numberModalHint = $"Dinero que hay en la cuenta al inicio de {MonthLabel}.";
        }
        else
        {
            // No hay saldo: intentamos sugerir el saldo final del mes anterior.
            var suggestion = await CalcularSaldoFinalMesAnterior();
            numberInput = suggestion;
            numberModalHint = suggestion is null
                ? $"Dinero que había en la cuenta al inicio de {MonthLabel}."
                : $"Sugerencia: saldo final del mes anterior ({FormatMoney(suggestion.Value)}). Ajústalo si no coincide con el banco.";
        }

        numberModalVisible = true;
    }

    /// <summary>
    /// Saldo final calculado del mes inmediatamente anterior, para sugerirlo
    /// como saldo inicial del mes actual. Devuelve null si falta información
    /// (sin opening_balance del mes anterior).
    /// </summary>
    private async Task<decimal?> CalcularSaldoFinalMesAnterior()
    {
        try
        {
            var prevDate = new DateTime(currentYear, currentMonth, 1).AddMonths(-1);
            int py = prevDate.Year, pm = prevDate.Month;

            var prevBudget = await Budgets.GetForMonthAsync(selectedAccountId, py, pm);
            if (prevBudget?.OpeningBalance is not decimal prevOpening)
                return null;

            // Gastos del mes anterior de la misma cuenta.
            var prevExpensesAll = await Expenses.GetByMonthAsync(py, pm);
            var prevSpent = prevExpensesAll
                .Where(e => e.AccountId == selectedAccountId)
                .Sum(e => e.Amount);

            if (IsCurrentAccountShared)
            {
                return prevOpening + (prevBudget.Amount) - prevSpent;
            }
            else
            {
                var prevSharedBudget = SharedAccount is null
                    ? null
                    : await Budgets.GetForMonthAsync(SharedAccount.Id, py, pm);
                var prevAporte = (prevSharedBudget?.Amount ?? 0m) * MyShareInShared;
                var prevIncome = prevBudget.Income ?? 0m;
                return prevOpening + prevIncome - prevAporte - prevSpent;
            }
        }
        catch
        {
            return null;
        }
    }

    private void OpenIncomeModal()
    {
        numberInput = currentBudget?.Income;
        numberModalTitle = "Nómina del mes";
        numberModalHint = $"Ingresos que entran en esta cuenta durante {MonthLabel}.";
        numberModalError = "";
        numberModalOnSave = async (value) =>
        {
            currentBudget = await Budgets.SetIncomeAsync(
                selectedAccountId, currentYear, currentMonth, value);
        };
        numberModalVisible = true;
    }

    private void OpenAmountModal()
    {
        numberInput = currentBudget?.Amount;
        numberModalTitle = "Aporte conjunto del mes";
        numberModalHint = $"Cantidad total que entra en la cuenta compartida en {MonthLabel} (la suma de los dos miembros).";
        numberModalError = "";
        numberModalOnSave = async (value) =>
        {
            currentBudget = await Budgets.SetAmountAsync(
                selectedAccountId, currentYear, currentMonth, value);
            if (IsCurrentAccountShared) sharedBudgetThisMonth = currentBudget;
        };
        numberModalVisible = true;
    }

    private void CloseNumberModal()
    {
        if (isSavingNumber) return;
        numberModalVisible = false;
        numberModalOnSave = null;
    }

    private async Task SaveNumberModal()
    {
        if (numberInput is null || numberModalOnSave is null) return;

        isSavingNumber = true;
        numberModalError = "";

        try
        {
            await numberModalOnSave(numberInput.Value);
            numberModalVisible = false;
            numberModalOnSave = null;
        }
        catch (Exception ex)
        {
            numberModalError = $"Error al guardar: {ex.Message}";
        }
        finally
        {
            isSavingNumber = false;
        }
    }

    // ===== Helpers de formato =====

    private static string FormatMoney(decimal amount) =>
        amount.ToString("N2", new CultureInfo("es-ES")) + " €";

    private static string SinDefinir() => "—";

    private static string BlockLabel(string block) => block switch
    {
        "fijo" => "Fijos",
        "comida" => "Comida",
        "variable" => "Variables",
        "minicompra" => "Minicompras",
        "individual" => "Individual",
        _ => block
    };
}
