@page "/mes"
@using System.Globalization
@using GastosApp.Client.Models
@using GastosApp.Client.Services
@inject AuthService Auth
@inject AccountService Accounts
@inject CategoryService CategorySvc
@inject ExpenseService Expenses
@inject BudgetService Budgets
@inject NavigationManager Nav

<PageTitle>Vista del mes</PageTitle>

@if (isLoading)
{
    <p>Cargando...</p>
}
else if (accounts.Count == 0)
{
    <p>No tienes cuentas. <a href="setup">Configura tus cuentas</a>.</p>
}
else
{
    <div class="container-narrow">

        @* Selector de mes *@
        <div class="d-flex justify-content-between align-items-center mb-3">
            <button class="btn btn-outline-secondary" @onclick="PreviousMonth">◀</button>
            <h4 class="m-0 text-capitalize">@MonthLabel</h4>
            <button class="btn btn-outline-secondary" @onclick="NextMonth">▶</button>
        </div>

        @* Botón añadir gasto rápido (preselecciona la cuenta activa) *@
        <a class="btn btn-primary w-100 mb-3"
           href="@($"nuevo-gasto?accountId={selectedAccountId}")">
            + Añadir gasto
        </a>

        @* Pestañas de cuenta *@
        <ul class="nav nav-tabs mb-3">
            @foreach (var acc in accounts)
            {
                <li class="nav-item">
                    <button class="nav-link @(selectedAccountId == acc.Id ? "active" : "")"
                            @onclick="() => SelectAccount(acc.Id)">
                        @acc.Name
                    </button>
                </li>
            }
        </ul>

        @* Bloque de previsión / gastado / resto *@
        <div class="budget-card mb-3">
            @if (currentBudget is null)
            {
                <div class="text-center py-2">
                    <div class="text-muted mb-2">Sin previsión definida este mes</div>
                    <div class="text-muted small mb-2">Gastado: @FormatMoney(currentTotal)</div>
                    <button class="btn btn-outline-primary btn-sm" @onclick="OpenBudgetModal">
                        Establecer previsión
                    </button>
                </div>
            }
            else
            {
                var budget = currentBudget.Amount;
                var spent = currentTotal;
                var remaining = budget - spent;
                var percent = budget > 0 ? Math.Min((double)(spent / budget) * 100, 100) : 0;
                var statusClass = StatusClass(spent, budget);

                <div class="budget-row">
                    <span class="budget-label">Previsión</span>
                    <span class="budget-value">@FormatMoney(budget)</span>
                    <button class="btn btn-sm btn-outline-secondary"
                            @onclick="OpenBudgetModal">Editar</button>
                </div>
                <div class="budget-row">
                    <span class="budget-label">Gastado</span>
                    <span class="budget-value">@FormatMoney(spent)</span>
                </div>
                <div class="budget-row">
                    <span class="budget-label">Resto</span>
                    <span class="budget-value @(remaining < 0 ? "text-danger" : "text-success") fw-bold">
                        @FormatMoney(remaining)
                    </span>
                </div>

                <div class="progress mt-2" style="height: 10px;">
                    <div class="progress-bar @statusClass"
                         role="progressbar"
                         style="width: @percent.ToString("F0", CultureInfo.InvariantCulture)%;"
                         aria-valuenow="@percent.ToString("F0", CultureInfo.InvariantCulture)"
                         aria-valuemin="0"
                         aria-valuemax="100"></div>
                </div>
                <div class="text-end small text-muted mt-1">
                    @percent.ToString("F0", new CultureInfo("es-ES"))% consumido
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        @* Bloques agrupados *@
        @if (currentExpenses.Count == 0)
        {
            <p class="text-muted text-center my-4">No hay gastos en esta cuenta este mes.</p>
        }
        else
        {
            @foreach (var blockKey in BlocksForSelectedAccount())
            {
                var blockExpenses = currentExpenses
                    .Where(e => CategoryOf(e.CategoryId)?.Block == blockKey)
                    .ToList();

                var blockTotal = blockExpenses.Sum(e => e.Amount);
                var isExpanded = expandedBlocks.Contains(blockKey);

                <div class="block-card mb-2">
                    <button class="block-header" @onclick="() => ToggleBlock(blockKey)">
                        <span class="block-arrow">@(isExpanded ? "▾" : "▸")</span>
                        <span class="block-name">@BlockLabel(blockKey)</span>
                        <span class="block-count text-muted">@blockExpenses.Count</span>
                        <span class="block-total">@FormatMoney(blockTotal)</span>
                    </button>

                    @if (isExpanded)
                    {
                        @if (blockExpenses.Count == 0)
                        {
                            <div class="block-empty text-muted small">Sin gastos en este bloque.</div>
                        }
                        else
                        {
                            <ul class="list-unstyled mb-0">
                                @foreach (var exp in blockExpenses.OrderByDescending(e => e.ExpenseDate))
                                {
                                    <li class="expense-row">
                                        <div class="expense-main">
                                            <div class="expense-title">
                                                @(string.IsNullOrWhiteSpace(exp.Description)
                                                    ? CategoryOf(exp.CategoryId)?.Name ?? "(sin categoría)"
                                                    : exp.Description)
                                            </div>
                                            <div class="expense-meta text-muted small">
                                                @exp.ExpenseDate.ToString("dd MMM", new CultureInfo("es-ES"))
                                                · @(CategoryOf(exp.CategoryId)?.Name ?? "—")
                                            </div>
                                        </div>
                                        <div class="expense-amount">@FormatMoney(exp.Amount)</div>
                                        <div class="expense-actions">
                                            <a class="btn btn-sm btn-outline-secondary"
                                               href="@($"nuevo-gasto?id={exp.Id}")">
                                                Editar
                                            </a>
                                            <button class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => HandleDelete(exp)">
                                                Borrar
                                            </button>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    }
                </div>
            }
        }
    </div>
}

@* Modal de borrado de gasto *@
<ConfirmModal @ref="confirmModal"
              Title="Borrar gasto"
              Message="Esta acción no se puede deshacer."
              ConfirmText="Borrar"
              ConfirmClass="btn-danger" />

@* Modal de edición de previsión *@
@if (budgetModalVisible)
{
    <div class="modal-backdrop-custom" @onclick="CloseBudgetModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <h5 class="mb-2">Previsión del mes</h5>
            <p class="text-muted small mb-3">
                Importe que esperas gastar en esta cuenta durante @MonthLabel.
            </p>

            <div class="input-group input-group-lg mb-3">
                <input type="number"
                       inputmode="decimal"
                       step="0.01"
                       min="0"
                       class="form-control"
                       placeholder="0,00"
                       @bind="budgetInput"
                       @bind:event="oninput" />
                <span class="input-group-text">€</span>
            </div>

            @if (!string.IsNullOrEmpty(budgetModalError))
            {
                <div class="alert alert-danger small">@budgetModalError</div>
            }

            <div class="d-flex gap-2 justify-content-end">
                <button class="btn btn-outline-secondary"
                        @onclick="CloseBudgetModal"
                        disabled="@isSavingBudget">
                    Cancelar
                </button>
                <button class="btn btn-primary"
                        @onclick="SaveBudget"
                        disabled="@(isSavingBudget || budgetInput is null or < 0)">
                    @(isSavingBudget ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

<style>
    .container-narrow {
        max-width: 600px;
        margin: 0 auto;
        padding: 16px;
    }

    .budget-card {
        background: white;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 14px;
    }

    .budget-row {
        display: grid;
        grid-template-columns: 1fr auto auto;
        gap: 12px;
        align-items: center;
        padding: 4px 0;
    }

    .budget-label { color: #6c757d; }
    .budget-value { font-weight: 500; }

    .block-card {
        border: 1px solid #dee2e6;
        border-radius: 8px;
        overflow: hidden;
        background: white;
    }

    .block-header {
        width: 100%;
        display: grid;
        grid-template-columns: 24px 1fr auto auto;
        gap: 8px;
        align-items: center;
        padding: 12px 14px;
        background: #f8f9fa;
        border: none;
        text-align: left;
        cursor: pointer;
    }

    .block-header:hover { background: #e9ecef; }

    .block-arrow { color: #6c757d; font-size: 0.9rem; }
    .block-name  { font-weight: 600; }
    .block-count {
        background: #dee2e6;
        border-radius: 10px;
        padding: 2px 8px;
        font-size: 0.8rem;
    }
    .block-total { font-weight: 600; }

    .block-empty { padding: 10px 14px; }

    .expense-row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 8px;
        padding: 10px 14px;
        border-top: 1px solid #f0f0f0;
        align-items: center;
    }

    .expense-main { min-width: 0; }
    .expense-title {
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .expense-meta { font-size: 0.8rem; }
    .expense-amount { font-weight: 600; }

    .expense-actions {
        grid-column: 1 / -1;
        display: flex;
        gap: 6px;
        margin-top: 4px;
    }

    /* Modal de edición de previsión (mismo look que ConfirmModal) */
    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1050;
        padding: 16px;
    }

    .modal-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        max-width: 400px;
        width: 100%;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }
</style>

@code {
    private bool isLoading = true;
    private string errorMessage = "";

    private List<Account> accounts = new();
    private Dictionary<Guid, Category> categoryMap = new();
    private List<Expense> currentExpenses = new();
    private MonthlyBudget? currentBudget;

    private Guid selectedAccountId;
    private int currentYear;
    private int currentMonth;

    // Bloques expandidos en la UI actual (vaciado al cambiar mes / cuenta).
    private HashSet<string> expandedBlocks = new();

    private ConfirmModal? confirmModal;

    // Estado del modal de edición de previsión
    private bool budgetModalVisible = false;
    private bool isSavingBudget = false;
    private decimal? budgetInput;
    private string budgetModalError = "";

    private static readonly string[] SharedBlocks = { "fijo", "comida", "variable", "minicompra" };
    private static readonly string[] PersonalBlocks = { "individual" };

    private string MonthLabel
    {
        get
        {
            var date = new DateTime(currentYear, currentMonth, 1);
            return date.ToString("MMMM yyyy", new CultureInfo("es-ES"));
        }
    }

    private decimal currentTotal => currentExpenses.Sum(e => e.Amount);

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("login");
            return;
        }

        var today = DateTime.Today;
        currentYear = today.Year;
        currentMonth = today.Month;

        accounts = (await Accounts.GetMyAccountsAsync())
            .OrderBy(a => a.IsShared)
            .ToList();

        if (accounts.Count == 0)
        {
            isLoading = false;
            return;
        }

        selectedAccountId = accounts.First().Id;

        await LoadAllCategories();
        await LoadMonthData();

        isLoading = false;
    }

    private async Task LoadAllCategories()
    {
        categoryMap.Clear();
        foreach (var acc in accounts)
        {
            var cats = await CategorySvc.GetByAccountAsync(acc.Id);
            foreach (var c in cats)
                categoryMap[c.Id] = c;
        }
    }

    private async Task LoadMonthData()
    {
        await LoadExpenses();
        await LoadBudget();
    }

    private async Task LoadExpenses()
    {
        try
        {
            errorMessage = "";
            var all = await Expenses.GetByMonthAsync(currentYear, currentMonth);
            currentExpenses = all
                .Where(e => e.AccountId == selectedAccountId)
                .ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar gastos: {ex.Message}";
            currentExpenses = new();
        }
    }

    private async Task LoadBudget()
    {
        try
        {
            currentBudget = await Budgets.GetForMonthAsync(selectedAccountId, currentYear, currentMonth);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar previsión: {ex.Message}";
            currentBudget = null;
        }
    }

    private async Task SelectAccount(Guid accountId)
    {
        selectedAccountId = accountId;
        expandedBlocks.Clear();
        await LoadMonthData();
    }

    private async Task PreviousMonth()
    {
        var date = new DateTime(currentYear, currentMonth, 1).AddMonths(-1);
        currentYear = date.Year;
        currentMonth = date.Month;
        expandedBlocks.Clear();
        await LoadMonthData();
    }

    private async Task NextMonth()
    {
        var date = new DateTime(currentYear, currentMonth, 1).AddMonths(1);
        currentYear = date.Year;
        currentMonth = date.Month;
        expandedBlocks.Clear();
        await LoadMonthData();
    }

    private void ToggleBlock(string blockKey)
    {
        if (!expandedBlocks.Add(blockKey))
            expandedBlocks.Remove(blockKey);
    }

    private Category? CategoryOf(Guid categoryId) =>
        categoryMap.TryGetValue(categoryId, out var c) ? c : null;

    private string[] BlocksForSelectedAccount()
    {
        var acc = accounts.FirstOrDefault(a => a.Id == selectedAccountId);
        return acc?.IsShared == true ? SharedBlocks : PersonalBlocks;
    }

    private async Task HandleDelete(Expense exp)
    {
        if (confirmModal is null) return;

        var confirmed = await confirmModal.ShowAsync();
        if (!confirmed) return;

        try
        {
            await Expenses.DeleteAsync(exp.Id);
            await LoadExpenses();
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudo borrar el gasto: {ex.Message}";
        }
    }

    private void OpenBudgetModal()
    {
        budgetInput = currentBudget?.Amount;
        budgetModalError = "";
        budgetModalVisible = true;
    }

    private void CloseBudgetModal()
    {
        if (isSavingBudget) return;
        budgetModalVisible = false;
    }

    private async Task SaveBudget()
    {
        if (budgetInput is null or < 0) return;

        isSavingBudget = true;
        budgetModalError = "";

        try
        {
            currentBudget = await Budgets.UpsertAsync(
                selectedAccountId,
                currentYear,
                currentMonth,
                budgetInput.Value);
            budgetModalVisible = false;
        }
        catch (Exception ex)
        {
            budgetModalError = $"Error al guardar: {ex.Message}";
        }
        finally
        {
            isSavingBudget = false;
        }
    }

    private static string StatusClass(decimal spent, decimal budget)
    {
        if (budget <= 0) return "bg-secondary";
        var ratio = spent / budget;
        if (ratio < 0.8m) return "bg-success";
        if (ratio < 1m)   return "bg-warning";
        return "bg-danger";
    }

    private static string FormatMoney(decimal amount) =>
        amount.ToString("N2", new CultureInfo("es-ES")) + " €";

    private static string BlockLabel(string block) => block switch
    {
        "fijo" => "Fijos",
        "comida" => "Comida",
        "variable" => "Variables",
        "minicompra" => "Minicompras",
        "individual" => "Individual",
        _ => block
    };
}
