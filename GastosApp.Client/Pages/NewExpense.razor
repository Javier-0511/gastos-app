@page "/nuevo-gasto"
@using GastosApp.Client.Models
@using GastosApp.Client.Services
@inject AuthService Auth
@inject AccountService Accounts
@inject CategoryService CategorySvc
@inject ExpenseService Expenses
@inject NavigationManager Nav

<PageTitle>@(IsEditMode ? "Editar gasto" : "Nuevo gasto")</PageTitle>

@if (isLoading)
{
    <p>Cargando...</p>
}
else if (accounts.Count == 0)
{
    <p>No tienes cuentas. <a href="setup">Configura tus cuentas</a>.</p>
}
else
{
    <div class="container-narrow">
        <h2 class="mb-3">@(IsEditMode ? "Editar gasto" : "Nuevo gasto")</h2>

        @* Pestañas de cuenta *@
        <ul class="nav nav-tabs mb-4">
            @foreach (var acc in accounts)
            {
                <li class="nav-item">
                    <button class="nav-link @(selectedAccountId == acc.Id ? "active" : "")"
                            @onclick="() => SelectAccount(acc.Id)">
                        @acc.Name
                    </button>
                </li>
            }
        </ul>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        @* Importe — input grande, teclado numérico en móvil *@
        <div class="mb-4 text-center">
            <div class="input-group input-group-lg justify-content-center amount-group">
                <input type="number"
                       inputmode="decimal"
                       step="0.01"
                       min="0"
                       class="form-control form-control-lg amount-input"
                       placeholder="0,00"
                       @bind="amount"
                       @bind:event="oninput" />
                <span class="input-group-text">€</span>
            </div>
        </div>

        @* Descripción *@
        <div class="mb-3">
            <label class="form-label">Descripción <span class="text-muted small">(opcional)</span></label>
            <input type="text"
                   class="form-control"
                   maxlength="100"
                   placeholder="Ej: super del jueves"
                   @bind="description"
                   @bind:event="oninput" />
        </div>

        @* Selector de bloque (solo si la cuenta tiene >1 bloque disponible) *@
        @if (BlocksForSelectedAccount().Length > 1)
        {
            <div class="mb-3">
                <label class="form-label">Bloque</label>
                <select class="form-select"
                        value="@selectedBlock"
                        @onchange="OnBlockChanged">
                    @foreach (var b in BlocksForSelectedAccount())
                    {
                        <option value="@b">@BlockLabel(b)</option>
                    }
                </select>
            </div>
        }

        @* Categoría — chips filtrados por bloque *@
        <div class="mb-3">
            <label class="form-label">Categoría</label>
            @if (categories.Count == 0)
            {
                <div class="alert alert-warning small mb-0">
                    No hay categorías en esta cuenta.
                    <a href="categorias">Crear categorías</a>.
                </div>
            }
            else if (filteredCategories.Count == 0)
            {
                <div class="alert alert-warning small mb-0">
                    No hay categorías en este bloque.
                    <a href="categorias">Crear una</a>.
                </div>
            }
            else
            {
                <div class="chips-row">
                    @foreach (var cat in filteredCategories)
                    {
                        <button type="button"
                                class="chip @(selectedCategoryId == cat.Id ? "chip-selected" : "")"
                                @onclick="() => selectedCategoryId = cat.Id">
                            @cat.Name
                        </button>
                    }
                </div>
            }
        </div>

        @* Fecha *@
        <div class="mb-4">
            <label class="form-label">Fecha</label>
            <input type="date" class="form-control" @bind="expenseDate" />
        </div>

        @* Botón guardar *@
        <button class="btn btn-primary btn-lg w-100"
                @onclick="HandleSave"
                disabled="@(isSaving || !IsValid)">
            @if (isSaving)
            {
                <span>Guardando...</span>
            }
            else
            {
                <span>@(IsEditMode ? "Guardar cambios" : "Guardar gasto")</span>
            }
        </button>

        @if (IsEditMode)
        {
            <button class="btn btn-outline-secondary w-100 mt-2" @onclick="HandleCancel">
                Cancelar
            </button>
        }
    </div>
}

<style>
    .container-narrow {
        max-width: 500px;
        margin: 0 auto;
        padding: 16px;
    }

    .amount-group {
        max-width: 280px;
        margin: 0 auto;
    }

    .amount-input {
        font-size: 2.5rem;
        text-align: right;
        font-weight: 600;
    }

    .chips-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .chip {
        padding: 8px 16px;
        border-radius: 20px;
        border: 1.5px solid #ced4da;
        background: white;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .chip:hover {
        border-color: var(--accent);
    }

    .chip-selected {
        background: var(--accent);
        color: white;
        border-color: var(--accent);
    }
</style>

@code {
    [SupplyParameterFromQuery]
    public Guid? Id { get; set; }

    [SupplyParameterFromQuery(Name = "accountId")]
    public Guid? PreselectedAccountId { get; set; }

    private bool IsEditMode => Id.HasValue && Id.Value != Guid.Empty;

    private bool isLoading = true;
    private bool isSaving = false;
    private string errorMessage = "";

    private List<Account> accounts = new();
    private List<Category> categories = new();

    private Guid selectedAccountId;
    private Guid? selectedCategoryId;
    private string? selectedBlock;
    private decimal? amount;
    private string description = "";
    private DateTime expenseDate = DateTime.Today;

    private static readonly string[] SharedBlocks = { "fijo", "comida", "variable", "minicompra" };
    private static readonly string[] PersonalBlocks = { "individual" };

    private List<Category> filteredCategories =>
        selectedBlock is null
            ? new List<Category>()
            : categories.Where(c => c.Block == selectedBlock).ToList();

    private bool IsValid =>
        selectedAccountId != Guid.Empty
        && selectedCategoryId.HasValue
        && amount is > 0;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("login");
            return;
        }

        accounts = (await Accounts.GetMyAccountsAsync())
            .OrderBy(a => a.IsShared)
            .ToList();

        if (accounts.Count == 0)
        {
            isLoading = false;
            return;
        }

        if (IsEditMode)
        {
            await LoadExpenseForEdit();
        }
        else
        {
            // Si la URL trae ?accountId={guid} y existe entre mis cuentas, lo usamos
            // como preselección. Si no, primera cuenta (personal) por defecto.
            var preselected = PreselectedAccountId.HasValue
                ? accounts.FirstOrDefault(a => a.Id == PreselectedAccountId.Value)
                : null;
            selectedAccountId = preselected?.Id ?? accounts.First().Id;
            await LoadCategories();
        }

        isLoading = false;
    }

    private async Task LoadExpenseForEdit()
    {
        try
        {
            var expense = await Expenses.GetByIdAsync(Id!.Value);
            if (expense is null)
            {
                errorMessage = "Gasto no encontrado.";
                selectedAccountId = accounts.First().Id;
                await LoadCategories();
                return;
            }

            selectedAccountId = expense.AccountId;
            await LoadCategories();

            // En edición pre-seleccionamos el bloque de la categoría del gasto
            // para que los chips se filtren igual que cuando se creó.
            var existingCat = categories.FirstOrDefault(c => c.Id == expense.CategoryId);
            if (existingCat is not null)
            {
                selectedBlock = existingCat.Block;
            }

            selectedCategoryId = expense.CategoryId;
            amount = expense.Amount;
            description = expense.Description ?? "";
            expenseDate = expense.ExpenseDate.Date;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar el gasto: {ex.Message}";
            selectedAccountId = accounts.First().Id;
            await LoadCategories();
        }
    }

    private async Task SelectAccount(Guid accountId)
    {
        selectedAccountId = accountId;
        selectedCategoryId = null;
        selectedBlock = null;
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        try
        {
            categories = (await CategorySvc.GetByAccountAsync(selectedAccountId))
                .OrderBy(c => c.Name)
                .ToList();
            errorMessage = "";

            // Auto-seleccionar el primer bloque si no hay ninguno seleccionado
            // y al menos hay categorías de un bloque.
            if (selectedBlock is null)
            {
                var blocks = BlocksForSelectedAccount();
                selectedBlock = blocks.FirstOrDefault(b => categories.Any(c => c.Block == b))
                                ?? blocks.FirstOrDefault();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar categorías: {ex.Message}";
        }
    }

    private void OnBlockChanged(ChangeEventArgs e)
    {
        selectedBlock = e.Value?.ToString();
        // Si la categoría seleccionada ya no pertenece al nuevo bloque, la limpiamos.
        if (selectedCategoryId.HasValue)
        {
            var current = categories.FirstOrDefault(c => c.Id == selectedCategoryId.Value);
            if (current is null || current.Block != selectedBlock)
            {
                selectedCategoryId = null;
            }
        }
    }

    private string[] BlocksForSelectedAccount()
    {
        var acc = accounts.FirstOrDefault(a => a.Id == selectedAccountId);
        return acc?.IsShared == true ? SharedBlocks : PersonalBlocks;
    }

    private static string BlockLabel(string block) => block switch
    {
        "fijo" => "Fijos",
        "comida" => "Comida",
        "variable" => "Variables",
        "minicompra" => "Minicompras",
        "individual" => "Individual",
        _ => block
    };

    private async Task HandleSave()
    {
        if (!IsValid || amount is null || selectedCategoryId is null) return;

        isSaving = true;
        errorMessage = "";

        try
        {
            if (IsEditMode)
            {
                await Expenses.UpdateAsync(
                    Id!.Value,
                    selectedAccountId,
                    selectedCategoryId.Value,
                    description.Trim(),
                    amount.Value,
                    expenseDate);
            }
            else
            {
                await Expenses.CreateAsync(
                    selectedAccountId,
                    selectedCategoryId.Value,
                    description.Trim(),
                    amount.Value,
                    expenseDate);
            }

            Nav.NavigateTo("mes");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al guardar el gasto: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void HandleCancel() => Nav.NavigateTo("mes");
}
