@page "/"
@using GastosApp.Client.Services
@inject AuthService Auth
@inject AccountService Accounts
@inject NavigationManager Nav

<PageTitle>Inicio</PageTitle>

@if (isChecking)
{
    <p>Cargando...</p>
}
else
{
    <h1>¡Hola, @Auth.CurrentUser?.Email!</h1>
    <p>Estás dentro de tu app de gastos.</p>

    <div class="d-grid gap-2 my-4" style="max-width: 400px;">
        <a href="nuevo-gasto" class="btn btn-primary btn-lg">
            + Añadir gasto
        </a>
        <a href="categorias" class="btn btn-outline-secondary">
            Gestionar categorías
        </a>
    </div>

    <button class="btn btn-outline-secondary btn-sm" @onclick="HandleLogout">
        Cerrar sesión
    </button>
}

@code {
    private bool isChecking = true;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("login");
            return;
        }

        var accounts = await Accounts.GetMyAccountsAsync();
        if (accounts.Count == 0)
        {
            Nav.NavigateTo("setup");
            return;
        }

        isChecking = false;
    }

    private async Task HandleLogout()
    {
        await Auth.SignOutAsync();
        Nav.NavigateTo("login");
    }
}
